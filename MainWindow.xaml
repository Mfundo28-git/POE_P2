<Window x:Class="POE_P2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_P2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <Grid x:Name="home_grid" Visibility="Visible">


            <!--  image -->
            <Image x:Name="logo" 
            
            Source="/logo.jpeg"
                
                />


            <!-- welcome message-->
            <TextBlock
                Text="Welcome to the Cyber Security Awereness Chatbot"
                TextAlignment="Center"
                Margin="0,10,0,243"
            FontSize="30"
            Foreground="Red"
                FontFamily="Bauhaus 93"
          
                />
            <TextBlock  
            Text="Please Click Button to Continue"
    TextAlignment="Center"
            FontSize="30"
            FontFamily="Bauhaus 93"
            Margin="0,250,0,0"
            
    />
            <!-- button to continue-->
            <Button x:Name="Procede" 
                Height="45"
                Width="300"
                Margin="0,200,0,0"
                Content="Procede"
                Click="proceed"
            Background="Red"
                />
        </Grid>
        <!-- Username grid -->
        <Grid x:Name="username_grid" Visibility="Hidden">
            <TextBox x:Name="usernames_input"
                     Height="60"
                     Background="YellowGreen"
                     Margin="350,252,32,120" />


            <TextBlock Text=" Username"
                       FontSize="30"
                       TextAlignment="Center"
                       Margin="100,257,455,92"
                       FontFamily="Bauhaus 93"/>

            <TextBlock Text="Please enter your username to continue"
           TextAlignment="Center"
           Margin="115,34,142,184"
                       FontSize="30"
           FontFamily="Bauhaus 93"
           />
            <Button
                Height="45"
                Width="270"
                Margin="0,250,0,0"
                Content="SUBMIT USERNAME"
                Click="submit_name"
                Background="Red"
                Foreground="YellowGreen"
                />

        </Grid>

        <!-- chat grid-->
        <Grid x:Name="chat_grid"
              Visibility="Hidden">
            <ListView x:Name="chats"
                        Height="300"
                        Margin="0,0,0,120"
                        />
            <TextBox x:Name="question"
                           Height="50"
                           Width="480"
                           Margin="0,300,300,0"
                     Background="YellowGreen"
                           />
            <Button Height="50" Width="290"
                    Margin="490,300,0,0"
            Content="send"
                    Click="send"
                    Background="Red"/>

        </Grid>


    </Grid>
</Window>
